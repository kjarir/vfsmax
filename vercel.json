{
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend",
      "routePrefix": "/_/backend"
    }
  },
  "crons": [
    {
      "path": "/_/backend/api/v1/monitoring/trigger-all",
      "schedule": "*/10 * * * *"
    }
  ]
}
